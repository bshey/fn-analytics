# Copy to .env and fill in. Never commit .env.
REDASH_URL=https://redash.devops.priv.prod.gcp.formlabs.cloud
# Redash -> avatar (top-right) -> Edit Profile -> copy API Key
REDASH_API_KEY=
REDASH_DATA_SOURCE_ID=13
# Only if Redash sits behind Cloudflare Access:
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
# Server port (localhost only)
PORT=4600
# Set MOCK=1 to run entirely on generated demo data (no VPN / API key needed)
# MOCK=1
# Intercom access token (Customer Service view) — Settings → Integrations → Developer Hub
INTERCOM_ACCESS_TOKEN=
